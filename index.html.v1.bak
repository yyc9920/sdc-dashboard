<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>SDC Dashboard · 초등부 세미나 학생 관리 데모</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <script defer src="https://unpkg.com/alpinejs@3.13.5/dist/cdn.min.js"></script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;600;700;900&family=Noto+Serif+KR:wght@400;600;900&family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=JetBrains+Mono:wght@400;600&family=Gaegu:wght@400;700&family=Inter:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">

  <style>
    html, body { font-family: 'Noto Sans KR', 'Inter', system-ui, sans-serif; }
    ::-webkit-scrollbar { width: 8px; height: 8px; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 8px; }

    /* ---------- Variant A · Minimal (Notion/Linear) ---------- */
    .v1 { background: #fafaf8; color: #1a1a1a; }
    .v1 .card { background: #fff; border: 1px solid #ececea; border-radius: 14px; }
    .v1 .display { font-family: 'Playfair Display', serif; letter-spacing: -0.02em; }
    .v1 .muted { color: #7b7b76; }
    .v1 .chip { background: #f2efe8; color: #6b6658; border-radius: 999px; padding: 2px 10px; font-size: 11px; font-weight:500; }
    .v1 .accent { color: #c6604a; }

    /* ---------- Variant B · Dark Modern (Vercel/Stripe) ---------- */
    .v2 { background:
        radial-gradient(1200px 600px at 10% -10%, rgba(56,189,248,.14), transparent 60%),
        radial-gradient(1000px 500px at 110% 10%, rgba(168,85,247,.16), transparent 60%),
        #07090d;
      color: #e5e7eb;
    }
    .v2 .card {
      background: linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.02));
      border: 1px solid rgba(255,255,255,.08);
      backdrop-filter: blur(12px);
      border-radius: 16px;
    }
    .v2 .glow { box-shadow: 0 0 0 1px rgba(56,189,248,.35), 0 10px 40px -10px rgba(56,189,248,.35); }
    .v2 .mono { font-family: 'JetBrains Mono', monospace; }
    .v2 .grad-text {
      background: linear-gradient(90deg,#7dd3fc,#a78bfa,#f472b6);
      -webkit-background-clip: text; background-clip: text; color: transparent;
    }
    .v2 .tag { background: rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.1); color:#cbd5e1; border-radius:8px; padding:2px 8px; font-size:11px; }

    /* ---------- Variant C · Playful (Kids) ---------- */
    .v3 { background: linear-gradient(160deg, #fff7e6 0%, #ffeef0 40%, #eaf7ff 100%); color:#2d1b3d; }
    .v3 .card { background:#fff; border-radius: 28px; border:3px solid #2d1b3d; box-shadow: 6px 6px 0 #2d1b3d; }
    .v3 .btn-pop { border:3px solid #2d1b3d; border-radius:999px; box-shadow: 3px 3px 0 #2d1b3d; transition: transform .12s; }
    .v3 .btn-pop:active { transform: translate(3px,3px); box-shadow:none; }
    .v3 .fun { font-family: 'Gaegu', 'Noto Sans KR', cursive; }
    .v3 .pill { border-radius:999px; padding: 4px 12px; font-weight:700; font-size:12px; border:2px solid #2d1b3d; }
    .v3 .badge { width: 56px; height:56px; border-radius:50%; display:grid; place-items:center; border:3px solid #2d1b3d; box-shadow: 3px 3px 0 #2d1b3d; font-size:26px; }

    /* ---------- Variant D · Corporate Pro ---------- */
    .v4 { background: #f3f4f6; color: #0f172a; font-family: 'Inter','Noto Sans KR',sans-serif; }
    .v4 .card { background:#fff; border-top: 3px solid #0a2540; border-radius: 4px; box-shadow: 0 1px 2px rgba(15,23,42,.05); }
    .v4 .kpi { background:#0a2540; color:#fff; border-radius:4px; }
    .v4 .kpi.gold { background: linear-gradient(135deg,#b8860b,#ffd76a); color:#1a1400; }
    .v4 .th { background:#0a2540; color:#fff; font-size:11px; letter-spacing:.08em; text-transform:uppercase; }
    .v4 .row:hover { background:#f8fafc; }
    .v4 .tabular { font-variant-numeric: tabular-nums; }

    /* ---------- Variant E · Bento Magazine ---------- */
    .v5 { background:#efeae2; color:#141414; }
    .v5 .bento { background:#fff; border-radius: 22px; padding: 22px; position:relative; overflow:hidden; }
    .v5 .bento.dark { background:#141414; color:#f5f1ea; }
    .v5 .bento.accent { background:#ff5a3c; color:#fff; }
    .v5 .bento.cream { background:#fff8ec; }
    .v5 .display { font-family:'Playfair Display', 'Noto Serif KR', serif; letter-spacing:-0.02em; }
    .v5 .micro { font-family:'JetBrains Mono', monospace; font-size:10px; letter-spacing:.14em; text-transform:uppercase; }
    .v5 .divider { height:1px; background: currentColor; opacity:.2; }

    /* helpers */
    .canvas-wrap { position: relative; width:100%; }
    [x-cloak] { display: none !important; }
  </style>
</head>
<body x-data="dashboard()" x-init="init()" x-cloak class="bg-slate-50">

<!-- ============== TOP NAV (picker) ============== -->
<header class="sticky top-0 z-50 backdrop-blur bg-white/90 border-b border-slate-200">
  <div class="max-w-[1400px] mx-auto px-5 py-3 flex items-center gap-4 flex-wrap">
    <div class="flex items-center gap-2">
      <div class="w-8 h-8 rounded-lg bg-slate-900 text-white grid place-items-center font-black">S</div>
      <div class="leading-tight">
        <div class="text-sm font-bold">SDC Dashboard</div>
        <div class="text-[11px] text-slate-500">초등부 세미나 · 학생 관리 데모</div>
      </div>
    </div>

    <nav class="flex gap-1 ml-2 flex-wrap">
      <template x-for="v in variants" :key="v.id">
        <button @click="setTab(v.id)"
          :class="currentTab===v.id ? 'bg-slate-900 text-white shadow' : 'text-slate-600 hover:bg-slate-100'"
          class="px-3 py-1.5 rounded-full text-xs font-semibold transition flex items-center gap-1.5">
          <span class="opacity-60" x-text="v.code"></span>
          <span x-text="v.label"></span>
        </button>
      </template>
    </nav>

    <div class="ml-auto flex items-center gap-3">
      <div class="text-[11px] text-slate-500 hidden md:block" x-text="currentVariant.desc"></div>
      <select x-model="selectedId" @change="rerender()"
        class="text-xs border border-slate-300 rounded-lg px-2 py-1.5 bg-white max-w-[180px]">
        <template x-for="s in sortedStudents" :key="s.id">
          <option :value="s.id" x-text="`${s.name} · ${s.grade}학년`"></option>
        </template>
      </select>
    </div>
  </div>
</header>

<!-- ============== VARIANT A · MINIMAL (Notion/Linear) ============== -->
<section x-show="currentTab===1" class="v1 min-h-screen">
  <div class="max-w-[1400px] mx-auto px-6 py-10">
    <!-- headline -->
    <div class="flex items-end justify-between flex-wrap gap-4 mb-10">
      <div>
        <div class="chip mb-3">Variant A · Minimal</div>
        <h1 class="display text-5xl font-bold leading-tight">학습만 남기고,<br><span class="accent italic">데이터로 가르친다.</span></h1>
        <p class="muted mt-3 max-w-lg">입학 시점부터 축적된 학생별 CLE 6개 지표와 교과 추이를 한 화면에서 읽습니다.</p>
      </div>
      <div class="flex gap-6 text-right">
        <div><div class="muted text-xs uppercase tracking-wider">총 학생</div><div class="display text-3xl" x-text="students.length"></div></div>
        <div><div class="muted text-xs uppercase tracking-wider">평균 CLE</div><div class="display text-3xl" x-text="avgCLE"></div></div>
        <div><div class="muted text-xs uppercase tracking-wider">TOEFL 평균</div><div class="display text-3xl" x-text="avgTOEFL"></div></div>
      </div>
    </div>

    <div class="grid grid-cols-12 gap-5">
      <!-- roster -->
      <aside class="col-span-12 lg:col-span-3">
        <div class="card p-4">
          <div class="flex items-center justify-between mb-3">
            <div class="text-xs font-semibold uppercase tracking-wider">명단 · ㄱ–ㅎ</div>
            <div class="muted text-[11px]" x-text="`${sortedStudents.length}명`"></div>
          </div>
          <div class="space-y-1 max-h-[560px] overflow-auto pr-1">
            <template x-for="s in sortedStudents" :key="s.id">
              <button @click="selectedId = s.id; rerender()"
                :class="selectedId===s.id ? 'bg-[#f2efe8] border-[#d8d1c0]' : 'border-transparent hover:bg-[#fafaf6]'"
                class="w-full text-left px-3 py-2.5 rounded-xl border flex items-center justify-between">
                <div>
                  <div class="font-semibold" x-text="s.name"></div>
                  <div class="muted text-[11px]" x-text="`${s.grade}학년 · ${s.enrollDate.slice(0,7)} 입학`"></div>
                </div>
                <div class="display text-sm" x-text="avgOfCLE(s)"></div>
              </button>
            </template>
          </div>
        </div>
      </aside>

      <!-- detail -->
      <main class="col-span-12 lg:col-span-9 space-y-5">
        <div class="card p-6">
          <div class="flex items-start justify-between flex-wrap gap-3">
            <div>
              <div class="chip mb-2">학생 프로파일</div>
              <h2 class="display text-4xl font-bold" x-text="selected.name"></h2>
              <div class="muted mt-1" x-text="`${selected.grade}학년 · ${selected.enrollDate} 입학 · 수강 ${monthsSince(selected.enrollDate)}개월차`"></div>
            </div>
            <div class="flex gap-6">
              <div><div class="muted text-xs uppercase tracking-wider">CLE 평균</div><div class="display text-3xl" x-text="avgOfCLE(selected)"></div></div>
              <div><div class="muted text-xs uppercase tracking-wider">교과 평균</div><div class="display text-3xl" x-text="avgSubject(selected)"></div></div>
              <div><div class="muted text-xs uppercase tracking-wider">TOEFL</div><div class="display text-3xl" x-text="selected.toefl.total"></div></div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-12 gap-5">
          <div class="card p-6 col-span-12 md:col-span-5">
            <div class="text-xs font-semibold uppercase tracking-wider mb-1">CLE · 어학 6개 지표</div>
            <div class="muted text-xs mb-3">독해 / 작문 / 청해 / 회화 / 문법 / 어휘</div>
            <div class="canvas-wrap" style="height:320px"><canvas id="v1-radar"></canvas></div>
          </div>
          <div class="card p-6 col-span-12 md:col-span-7">
            <div class="flex items-center justify-between mb-3">
              <div>
                <div class="text-xs font-semibold uppercase tracking-wider">교과 성적 추이</div>
                <div class="muted text-xs">월례 · 중간 · 기말</div>
              </div>
              <div class="flex gap-3 text-[11px] muted">
                <span><span class="inline-block w-2 h-2 rounded-full bg-slate-400 mr-1"></span>월례</span>
                <span><span class="inline-block w-2 h-2 rounded-full bg-amber-500 mr-1"></span>중간</span>
                <span><span class="inline-block w-2 h-2 rounded-full bg-rose-500 mr-1"></span>기말</span>
              </div>
            </div>
            <div class="canvas-wrap" style="height:320px"><canvas id="v1-line"></canvas></div>
          </div>

          <div class="card p-6 col-span-12 md:col-span-5">
            <div class="text-xs font-semibold uppercase tracking-wider mb-3">TOEFL</div>
            <div class="display text-5xl mb-4" x-text="selected.toefl.total"><span class="muted text-lg">/120</span></div>
            <div class="grid grid-cols-2 gap-3">
              <template x-for="k in ['reading','listening','speaking','writing']" :key="k">
                <div class="p-3 rounded-xl bg-[#faf8f2]">
                  <div class="muted text-[11px] uppercase" x-text="k"></div>
                  <div class="display text-2xl" x-text="selected.toefl[k]"><span class="muted text-sm">/30</span></div>
                </div>
              </template>
            </div>
          </div>

          <div class="card p-6 col-span-12 md:col-span-7">
            <div class="text-xs font-semibold uppercase tracking-wider mb-3">수상 · 활동 이력</div>
            <ul class="divide-y divide-[#ececea]">
              <template x-for="a in selected.awards" :key="a.title+a.date">
                <li class="py-2.5 flex items-center justify-between">
                  <div>
                    <div class="font-medium" x-text="a.title"></div>
                    <div class="muted text-xs" x-text="a.org"></div>
                  </div>
                  <div class="muted text-xs" x-text="a.date"></div>
                </li>
              </template>
            </ul>
          </div>
        </div>
      </main>
    </div>
  </div>
</section>

<!-- ============== VARIANT B · DARK MODERN ============== -->
<section x-show="currentTab===2" class="v2 min-h-screen">
  <div class="max-w-[1400px] mx-auto px-6 py-10">
    <div class="flex items-end justify-between flex-wrap gap-4 mb-8">
      <div>
        <div class="mono text-[11px] tracking-[0.2em] text-sky-300/70 mb-2">VARIANT B · DARK_MODE</div>
        <h1 class="text-5xl font-black leading-tight">
          <span class="grad-text">DATA-DRIVEN</span><br>
          <span>LEARNING OPS</span>
        </h1>
        <p class="mt-3 text-slate-400 max-w-lg text-sm">실시간처럼 읽히는 학습 지표. 입학 후 모든 점수가 한 곳에 흐릅니다.</p>
      </div>
      <div class="grid grid-cols-3 gap-3">
        <div class="card glow px-5 py-3">
          <div class="mono text-[10px] text-sky-300/80">STUDENTS</div>
          <div class="text-3xl font-bold mono" x-text="students.length"></div>
        </div>
        <div class="card px-5 py-3">
          <div class="mono text-[10px] text-purple-300/80">AVG CLE</div>
          <div class="text-3xl font-bold mono" x-text="avgCLE"></div>
        </div>
        <div class="card px-5 py-3">
          <div class="mono text-[10px] text-pink-300/80">AVG TOEFL</div>
          <div class="text-3xl font-bold mono" x-text="avgTOEFL"></div>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-12 gap-4">
      <aside class="col-span-12 lg:col-span-3">
        <div class="card p-4">
          <div class="flex items-center justify-between mb-3">
            <div class="mono text-[10px] tracking-[0.2em] text-slate-400">ROSTER · A→Z</div>
            <div class="tag mono" x-text="sortedStudents.length + ' REC'"></div>
          </div>
          <div class="space-y-1.5 max-h-[560px] overflow-auto pr-1">
            <template x-for="s in sortedStudents" :key="s.id">
              <button @click="selectedId = s.id; rerender()"
                :class="selectedId===s.id ? 'bg-white/10 border-sky-400/50 glow' : 'border-white/5 hover:bg-white/5'"
                class="w-full text-left px-3 py-2.5 rounded-xl border flex items-center gap-2">
                <div class="w-1.5 h-1.5 rounded-full" :style="selectedId===s.id ? 'background:#38bdf8; box-shadow:0 0 8px #38bdf8':'background:#475569'"></div>
                <div class="flex-1">
                  <div class="text-sm font-semibold" x-text="s.name"></div>
                  <div class="text-[11px] text-slate-400" x-text="`G${s.grade} · ${s.enrollDate.slice(2,7)}`"></div>
                </div>
                <div class="mono text-xs text-sky-300" x-text="avgOfCLE(s)"></div>
              </button>
            </template>
          </div>
        </div>
      </aside>

      <main class="col-span-12 lg:col-span-9 space-y-4">
        <div class="card p-6 flex items-center justify-between flex-wrap gap-4">
          <div>
            <div class="mono text-[10px] text-sky-300/80 tracking-[0.2em]">SUBJECT · PROFILE</div>
            <h2 class="text-4xl font-black mt-1" x-text="selected.name"></h2>
            <div class="text-sm text-slate-400 mt-1" x-text="`Grade ${selected.grade} · Enrolled ${selected.enrollDate} · ${monthsSince(selected.enrollDate)}mo`"></div>
          </div>
          <div class="grid grid-cols-3 gap-3 text-right">
            <div><div class="mono text-[10px] text-sky-300/80">CLE</div><div class="text-2xl font-bold mono" x-text="avgOfCLE(selected)"></div></div>
            <div><div class="mono text-[10px] text-purple-300/80">SUBJECT</div><div class="text-2xl font-bold mono" x-text="avgSubject(selected)"></div></div>
            <div><div class="mono text-[10px] text-pink-300/80">TOEFL</div><div class="text-2xl font-bold mono" x-text="selected.toefl.total"></div></div>
          </div>
        </div>

        <div class="grid grid-cols-12 gap-4">
          <div class="card p-6 col-span-12 md:col-span-5">
            <div class="mono text-[10px] tracking-[0.2em] text-slate-400 mb-1">CLE_HEXAGON</div>
            <div class="text-slate-300 text-sm mb-3">어학 6개 지표 분포</div>
            <div class="canvas-wrap" style="height:320px"><canvas id="v2-radar"></canvas></div>
          </div>
          <div class="card p-6 col-span-12 md:col-span-7">
            <div class="flex items-center justify-between mb-3">
              <div>
                <div class="mono text-[10px] tracking-[0.2em] text-slate-400">SCORE_STREAM</div>
                <div class="text-slate-300 text-sm">월례 / 중간 / 기말</div>
              </div>
              <div class="flex gap-2 text-[11px]">
                <span class="tag mono"><span class="inline-block w-2 h-2 rounded-full bg-sky-400 mr-1"></span>MON</span>
                <span class="tag mono"><span class="inline-block w-2 h-2 rounded-full bg-purple-400 mr-1"></span>MID</span>
                <span class="tag mono"><span class="inline-block w-2 h-2 rounded-full bg-pink-400 mr-1"></span>FIN</span>
              </div>
            </div>
            <div class="canvas-wrap" style="height:320px"><canvas id="v2-line"></canvas></div>
          </div>

          <div class="card p-6 col-span-12 md:col-span-5">
            <div class="mono text-[10px] tracking-[0.2em] text-slate-400 mb-2">TOEFL_iBT</div>
            <div class="flex items-baseline gap-2 mb-4">
              <div class="text-5xl font-black mono grad-text" x-text="selected.toefl.total"></div>
              <div class="mono text-slate-500">/ 120</div>
            </div>
            <div class="grid grid-cols-2 gap-2">
              <template x-for="k in ['reading','listening','speaking','writing']" :key="k">
                <div class="px-3 py-2 rounded-lg bg-white/5 border border-white/5">
                  <div class="mono text-[10px] text-slate-400 uppercase" x-text="k"></div>
                  <div class="mono text-2xl font-bold" x-text="selected.toefl[k]"></div>
                </div>
              </template>
            </div>
          </div>

          <div class="card p-6 col-span-12 md:col-span-7">
            <div class="mono text-[10px] tracking-[0.2em] text-slate-400 mb-3">AWARDS & ACTIVITIES</div>
            <div class="space-y-2">
              <template x-for="a in selected.awards" :key="a.title+a.date">
                <div class="flex items-center justify-between p-3 rounded-xl bg-white/5 border border-white/5 hover:border-sky-400/30">
                  <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-sky-400/20 to-purple-400/20 grid place-items-center text-lg">🏆</div>
                    <div>
                      <div class="font-semibold text-sm" x-text="a.title"></div>
                      <div class="text-[11px] text-slate-400" x-text="a.org"></div>
                    </div>
                  </div>
                  <div class="mono text-[11px] text-slate-500" x-text="a.date"></div>
                </div>
              </template>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>
</section>

<!-- ============== VARIANT C · PLAYFUL KIDS ============== -->
<section x-show="currentTab===3" class="v3 min-h-screen">
  <div class="max-w-[1400px] mx-auto px-6 py-10">
    <div class="flex items-end justify-between flex-wrap gap-4 mb-8">
      <div>
        <div class="pill bg-yellow-300 inline-block mb-3 fun text-base">📚 Variant C · 키즈 친화</div>
        <h1 class="fun text-6xl font-bold leading-tight">우리반<br><span class="text-rose-500">성장 다이어리 ✨</span></h1>
        <p class="mt-3 max-w-lg text-base">입학부터 오늘까지, 한 명 한 명의 성장을 따뜻하게 기록해요.</p>
      </div>
      <div class="grid grid-cols-3 gap-3">
        <div class="card px-4 py-3 text-center bg-yellow-200">
          <div class="fun text-xs">친구들</div>
          <div class="fun text-4xl font-bold" x-text="students.length + '명'"></div>
        </div>
        <div class="card px-4 py-3 text-center bg-rose-200">
          <div class="fun text-xs">반 CLE</div>
          <div class="fun text-4xl font-bold" x-text="avgCLE"></div>
        </div>
        <div class="card px-4 py-3 text-center bg-sky-200">
          <div class="fun text-xs">TOEFL</div>
          <div class="fun text-4xl font-bold" x-text="avgTOEFL"></div>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-12 gap-5">
      <aside class="col-span-12 lg:col-span-3">
        <div class="card p-5">
          <div class="flex items-center gap-2 mb-3">
