              <div class="fun text-xl font-bold">친구들 🎒</div>
              <div class="text-xs">가나다 순</div>
            </div>
          </div>
          <div class="space-y-2 max-h-[560px] overflow-auto pr-1">
            <template x-for="(s,i) in sortedStudents" :key="s.id">
              <button @click="selectedId = s.id; rerender()"
                :class="selectedId===s.id ? 'bg-yellow-200' : 'bg-white hover:bg-yellow-50'"
                class="btn-pop w-full text-left px-3 py-2.5 flex items-center gap-2.5">
                <div class="w-9 h-9 rounded-full grid place-items-center text-lg border-2 border-[#2d1b3d]"
                     :style="`background:${avatarColor(i)}`" x-text="s.name[0]"></div>
                <div class="flex-1">
                  <div class="fun text-lg leading-none" x-text="s.name"></div>
                  <div class="text-[11px]" x-text="`${s.grade}학년 · ${s.enrollDate.slice(0,4)}년 입학`"></div>
                </div>
                <div class="fun text-base font-bold" x-text="avgOfCLE(s)"></div>
              </button>
            </template>
          </div>
        </div>
      </aside>

      <main class="col-span-12 lg:col-span-9 space-y-5">
        <div class="card p-6 flex items-center gap-5 flex-wrap">
          <div class="w-24 h-24 rounded-full grid place-items-center text-4xl border-4 border-[#2d1b3d] shadow-[4px_4px_0_#2d1b3d]"
               :style="`background:${avatarColor(selectedIdx)}`" x-text="selected.name[0]"></div>
          <div class="flex-1">
            <div class="fun text-4xl font-bold leading-tight" x-text="selected.name + ' 친구 🌟'"></div>
            <div class="text-sm mt-1" x-text="`${selected.grade}학년 · ${selected.enrollDate} 입학 · 함께한 지 ${monthsSince(selected.enrollDate)}개월`"></div>
            <div class="flex gap-2 mt-2 flex-wrap">
              <span class="pill bg-mint-200" style="background:#b8ecd2" x-text="`CLE ${avgOfCLE(selected)}점`"></span>
              <span class="pill bg-yellow-200" x-text="`교과 ${avgSubject(selected)}점`"></span>
              <span class="pill bg-rose-200" x-text="`TOEFL ${selected.toefl.total}`"></span>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-12 gap-5">
          <div class="card p-6 col-span-12 md:col-span-5">
            <div class="fun text-2xl font-bold mb-1">✏️ 6가지 어학 실력</div>
            <div class="text-xs mb-3">독해 · 작문 · 청해 · 회화 · 문법 · 어휘</div>
            <div class="canvas-wrap" style="height:320px"><canvas id="v3-radar"></canvas></div>
          </div>
          <div class="card p-6 col-span-12 md:col-span-7">
            <div class="fun text-2xl font-bold mb-1">📈 시험 점수 타임라인</div>
            <div class="text-xs mb-3">월례 · 중간 · 기말</div>
            <div class="canvas-wrap" style="height:320px"><canvas id="v3-line"></canvas></div>
          </div>

          <div class="card p-6 col-span-12 md:col-span-5 bg-gradient-to-br from-sky-100 to-indigo-100">
            <div class="fun text-2xl font-bold mb-3">🎯 TOEFL 성적표</div>
            <div class="flex items-end gap-2 mb-4">
              <div class="fun text-7xl font-bold text-rose-600" x-text="selected.toefl.total"></div>
              <div class="fun text-lg pb-3">/ 120</div>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <template x-for="(k,i) in ['reading','listening','speaking','writing']" :key="k">
                <div class="p-3 rounded-2xl border-2 border-[#2d1b3d] shadow-[3px_3px_0_#2d1b3d] text-center"
                     :style="`background:${['#fff3b0','#b8ecd2','#ffc6c9','#c9d7ff'][i]}`">
                  <div class="text-[11px] font-bold uppercase" x-text="k"></div>
                  <div class="fun text-3xl font-bold" x-text="selected.toefl[k]"></div>
                </div>
              </template>
            </div>
          </div>

          <div class="card p-6 col-span-12 md:col-span-7">
            <div class="fun text-2xl font-bold mb-3">🏆 자랑할 만한 순간들</div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
              <template x-for="(a,i) in selected.awards" :key="a.title+a.date">
                <div class="p-4 rounded-2xl border-3 border-[#2d1b3d] shadow-[3px_3px_0_#2d1b3d] flex items-center gap-3"
                     :style="`background:${['#fff3b0','#ffc6c9','#b8ecd2','#c9d7ff','#fde5c3','#e9d5ff'][i%6]}`">
                  <div class="text-3xl" x-text="a.icon || '🎖️'"></div>
                  <div class="flex-1">
                    <div class="fun text-lg font-bold leading-none" x-text="a.title"></div>
                    <div class="text-[11px] mt-1" x-text="`${a.org} · ${a.date}`"></div>
                  </div>
                </div>
              </template>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>
</section>

