function genTests(enrollDate, monthly, midterm, final){
  const start = new Date(enrollDate);
  const tests = [];
  // monthly: every ~1.5 months starting at enroll+1m
  monthly.forEach((score, i) => {
    const d = new Date(start); d.setMonth(d.getMonth() + 1 + i*1.5|0);
    tests.push({ date: d.toISOString().slice(0,10), type:'월례', score });
  });
  midterm.forEach((score, i) => {
    const d = new Date(start); d.setMonth(d.getMonth() + 4 + i*6);
    tests.push({ date: d.toISOString().slice(0,10), type:'중간', score });
  });
  final.forEach((score, i) => {
    const d = new Date(start); d.setMonth(d.getMonth() + 7 + i*6);
    tests.push({ date: d.toISOString().slice(0,10), type:'기말', score });
  });
  tests.sort((a,b) => a.date.localeCompare(b.date));
  return tests;
}

/* ==========================================================
 * Alpine component
 * ========================================================= */
function dashboard(){
  return {
    currentTab: 1,
    selectedId: 1,
    students: MOCK_STUDENTS,
    variants: [
      { id:1, code:'A', label:'미니멀',   desc:'Notion / Linear 스타일 · 단정한 타이포' },
      { id:2, code:'B', label:'다크모드', desc:'Vercel / Stripe 스타일 · 글래스모피즘' },
      { id:3, code:'C', label:'키즈',     desc:'초등부 친화 · 팝업 컬러 · 손글씨체' },
      { id:4, code:'D', label:'코퍼릿',   desc:'전통적 대시보드 · 표 중심 · Bloomberg 느낌' },
      { id:5, code:'E', label:'벤토',     desc:'매거진 벤토 그리드 · 디스플레이 타이포' },
    ],
    charts: {},

    get currentVariant(){ return this.variants.find(v => v.id === this.currentTab); },
    get sortedStudents(){ return [...this.students].sort((a,b) => a.name.localeCompare(b.name,'ko')); },
    get selected(){ return this.students.find(s => s.id == this.selectedId) || this.students[0]; },
    get selectedIdx(){ return this.sortedStudents.findIndex(s => s.id == this.selectedId); },
    get avgCLE(){
      const total = this.students.reduce((sum,s) => sum + Number(this.avgOfCLE(s)), 0);
      return (total / this.students.length).toFixed(1);
    },
    get avgTOEFL(){
      const total = this.students.reduce((sum,s) => sum + s.toefl.total, 0);
      return (total / this.students.length).toFixed(0);
    },
    get classAvgSubject(){
      const total = this.students.reduce((sum,s) => sum + Number(this.avgSubject(s)), 0);
      return (total / this.students.length).toFixed(1);
    },

    avgOfCLE(s){
      const v = Object.values(s.cle);
      return (v.reduce((a,b) => a+b, 0) / v.length).toFixed(1);
    },
    avgSubject(s){
      if (!s.tests.length) return '0';
      return (s.tests.reduce((a,t) => a+t.score, 0) / s.tests.length).toFixed(1);
    },
    monthsSince(date){
      const d = new Date(date), now = new Date();
      return (now.getFullYear()-d.getFullYear())*12 + (now.getMonth()-d.getMonth());
    },
    avatarColor(i){
      const palette = ['#fff3b0','#b8ecd2','#ffc6c9','#c9d7ff','#fde5c3','#e9d5ff','#ffe0b8','#d0f4de','#ffd1dc','#c6e2ff','#fde8f6','#e0f4ff'];
      return palette[(i||0) % palette.length];
    },

    setTab(id){ this.currentTab = id; this.rerender(); },
    rerender(){
      // destroy all charts then render for current tab on next frame
      Object.values(this.charts).forEach(c => c?.destroy());
      this.charts = {};
      requestAnimationFrame(() => this.renderCharts(this.currentTab));
    },
    init(){
      this.$watch('currentTab', () => this.rerender());
      requestAnimationFrame(() => this.renderCharts(this.currentTab));
    },

    renderCharts(tab){
      const themes = {
        1: { // minimal
          radar:{ fill:'rgba(198,96,74,.18)', stroke:'#c6604a', grid:'#e8e4dc', label:'#555', bg:'#fff' },
          line: { mon:'#94a3b8', mid:'#f59e0b', fin:'#e11d48', grid:'#efece6', text:'#333' }
        },
        2: { // dark
          radar:{ fill:'rgba(125,211,252,.2)', stroke:'#7dd3fc', grid:'rgba(255,255,255,.08)', label:'#cbd5e1', bg:'transparent' },
          line: { mon:'#7dd3fc', mid:'#a78bfa', fin:'#f472b6', grid:'rgba(255,255,255,.08)', text:'#cbd5e1' }
        },
        3: { // playful
          radar:{ fill:'rgba(251,113,133,.25)', stroke:'#e11d48', grid:'#2d1b3d22', label:'#2d1b3d', bg:'#fff' },
          line: { mon:'#38bdf8', mid:'#f59e0b', fin:'#e11d48', grid:'#2d1b3d22', text:'#2d1b3d' }
        },
        4: { // corporate
          radar:{ fill:'rgba(10,37,64,.15)', stroke:'#0a2540', grid:'#cbd5e1', label:'#475569', bg:'#fff' },
          line: { mon:'#64748b', mid:'#b8860b', fin:'#0a2540', grid:'#e2e8f0', text:'#334155' }
        },
        5: { // bento
          radar:{ fill:'rgba(255,90,60,.22)', stroke:'#ff5a3c', grid:'rgba(20,20,20,.12)', label:'#141414', bg:'transparent' },
          line: { mon:'#141414', mid:'#ff5a3c', fin:'#b8860b', grid:'rgba(20,20,20,.12)', text:'#141414' }
        },
      };
      const theme = themes[tab];
      if (!theme) return;
      const s = this.selected;
      const cleLabels = ['독해','작문','청해','회화','문법','어휘'];
      const cleData = ['reading','writing','listening','speaking','grammar','vocab'].map(k => s.cle[k]);

      // RADAR
      const radarId = `v${tab}-radar`;
      const radarEl = document.getElementById(radarId);
      if (radarEl) {
        const prev = Chart.getChart(radarEl); if (prev) prev.destroy();
        this.charts[radarId] = new Chart(radarEl, {
          type:'radar',
          data:{
            labels: cleLabels,
            datasets:[{
              label: s.name, data: cleData,
              backgroundColor: theme.radar.fill, borderColor: theme.radar.stroke, borderWidth:2,
              pointBackgroundColor: theme.radar.stroke, pointRadius:4, pointHoverRadius:6
            }]
          },
          options:{
            responsive:true, maintainAspectRatio:false,
            plugins:{ legend:{ display:false } },
            scales:{ r:{
              min:0, max:100,
              grid:{ color: theme.radar.grid }, angleLines:{ color: theme.radar.grid },
              pointLabels:{ color: theme.radar.label, font:{ size:12, weight:'600' } },
              ticks:{ display:false, stepSize:20 }
            }}
          }
        });
      }

      // LINE
      const lineId = `v${tab}-line`;
      const lineEl = document.getElementById(lineId);
      if (lineEl) {
        const prev = Chart.getChart(lineEl); if (prev) prev.destroy();
        const pts = s.tests;
        const typeColor = (t) => t==='월례' ? theme.line.mon : t==='중간' ? theme.line.mid : theme.line.fin;
        const typeRadius = (t) => t==='월례' ? 4 : t==='중간' ? 6 : 7;
        this.charts[lineId] = new Chart(lineEl, {
          type:'line',
          data:{
            labels: pts.map(p => p.date.slice(2,7)),
            datasets:[{
              label:'점수',
              data: pts.map(p => p.score),
              borderColor: theme.line.mon,
              backgroundColor: 'transparent',
              borderWidth: 2,
              tension: 0.35,
              pointBackgroundColor: pts.map(p => typeColor(p.type)),
              pointBorderColor: pts.map(p => typeColor(p.type)),
              pointRadius: pts.map(p => typeRadius(p.type)),
              pointHoverRadius: pts.map(p => typeRadius(p.type) + 2),
              pointStyle: pts.map(p => p.type==='월례' ? 'circle' : p.type==='중간' ? 'rectRounded' : 'rectRot'),
            }]
          },
          options:{
            responsive:true, maintainAspectRatio:false,
            plugins:{
              legend:{ display:false },
              tooltip:{
                callbacks:{
                  title: (items) => pts[items[0].dataIndex].date,
                  label: (item) => `${pts[item.dataIndex].type} · ${item.parsed.y}점`
                }
              }
            },
            scales:{
              x:{ grid:{ color: theme.line.grid }, ticks:{ color: theme.line.text, font:{size:11} } },
              y:{ min:50, max:100, grid:{ color: theme.line.grid }, ticks:{ color: theme.line.text, font:{size:11} } }
            }
          }
        });
      }
    }
  };
}
</script>
</body>
</html>
